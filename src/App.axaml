<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="Zaide.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- Palette raw colors (shared source of truth — matched to concept.png) -->
        <Color x:Key="PrimaryAccentColor">#066ADB</Color>
        <Color x:Key="SoftAccentColor">#3ED3E4</Color>
        <Color x:Key="DeepBaseColor">#0E1520</Color>
        <Color x:Key="TextActiveColor">#E8EAF2</Color>
        <Color x:Key="SurfaceBaseColor">#131B27</Color>
        <Color x:Key="PanelDeepColor">#111822</Color>
        <Color x:Key="SurfacePanelColor">#1A2330</Color>
        <Color x:Key="SurfaceBorderColor">#253040</Color>

        <!-- Palette brushes (derived from the colors above) -->
        <SolidColorBrush x:Key="PrimaryAccent" Color="{StaticResource PrimaryAccentColor}" />
        <SolidColorBrush x:Key="SoftAccent" Color="{StaticResource SoftAccentColor}" />
        <SolidColorBrush x:Key="DeepBase" Color="{StaticResource DeepBaseColor}" />
        <SolidColorBrush x:Key="TextActive" Color="{StaticResource TextActiveColor}" />
        <SolidColorBrush x:Key="SurfaceBase" Color="{StaticResource SurfaceBaseColor}" />
        <SolidColorBrush x:Key="PanelDeep" Color="{StaticResource PanelDeepColor}" />
        <SolidColorBrush x:Key="SurfacePanel" Color="{StaticResource SurfacePanelColor}" />
        <SolidColorBrush x:Key="SurfaceBorder" Color="{StaticResource SurfaceBorderColor}" />

        <!-- Glassmorphism translucent surfaces -->
        <Color x:Key="GlassBaseColor">#151E2B</Color>
        <Color x:Key="GlassDeepColor">#111820</Color>
        <Color x:Key="GlassPanelColor">#1C2635</Color>
        <Color x:Key="GlassBorderColor">#3A4A61</Color>
        <SolidColorBrush x:Key="GlassBase" Color="{StaticResource GlassBaseColor}" Opacity="0.78" />
        <SolidColorBrush x:Key="GlassDeep" Color="{StaticResource GlassDeepColor}" Opacity="0.82" />
        <SolidColorBrush x:Key="GlassPanel" Color="{StaticResource GlassPanelColor}" Opacity="0.72" />
        <SolidColorBrush x:Key="GlassBorder" Color="{StaticResource GlassBorderColor}" Opacity="0.35" />

        <!-- Derived accent colors -->
        <Color x:Key="WarningColor">#FCBB47</Color>
        <Color x:Key="SuccessColor">#28A745</Color>
        <Color x:Key="TextSecondaryColor">#9AA5B5</Color>
        <Color x:Key="SeparatorColor">#1E2937</Color>
        <Color x:Key="HoverSurfaceColor">#1B2736</Color>
        <SolidColorBrush x:Key="Warning" Color="{StaticResource WarningColor}" />
        <SolidColorBrush x:Key="Success" Color="{StaticResource SuccessColor}" />
        <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}" />
        <SolidColorBrush x:Key="Separator" Color="{StaticResource SeparatorColor}" />
        <SolidColorBrush x:Key="HoverSurface" Color="{StaticResource HoverSurfaceColor}" />

        <!-- Semantic derived colors -->
        <Color x:Key="TextContentColor">#C8CED8</Color>
        <Color x:Key="ActiveHighlightColor">#1E2D3F</Color>
        <Color x:Key="CloseHoverColor">#223ED3E4</Color>
        <SolidColorBrush x:Key="TextContent" Color="{StaticResource TextContentColor}" />
        <SolidColorBrush x:Key="ActiveHighlight" Color="{StaticResource ActiveHighlightColor}" />
        <SolidColorBrush x:Key="CloseHover" Color="{StaticResource CloseHoverColor}" />

        <!-- Override AvaloniaEdit SearchPanel to use Zaide palette -->
        <SolidColorBrush x:Key="SearchPanelBackgroundBrush" Color="{StaticResource SurfacePanelColor}" />
        <SolidColorBrush x:Key="SearchPanelBorderBrush" Color="{StaticResource SurfaceBorderColor}" />
    </Application.Resources>

    <Application.Styles>
        <fluent:FluentTheme />
        <StyleInclude Source="avares://Semi.Avalonia/SemiTheme.axaml" />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    </Application.Styles>
</Application>
