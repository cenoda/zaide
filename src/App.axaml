<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fluent="clr-namespace:Avalonia.Themes.Fluent;assembly=Avalonia.Themes.Fluent"
             x:Class="Zaide.App"
             RequestedThemeVariant="Dark">

    <Application.Resources>
        <!-- Palette raw colors (shared source of truth — matched to concept.png) -->
        <Color x:Key="PrimaryAccentColor">#066ADB</Color>
        <Color x:Key="SoftAccentColor">#3ED3E4</Color>
        <Color x:Key="DeepBaseColor">#0A0F19</Color>
        <Color x:Key="TextActiveColor">#E3E4F4</Color>
        <Color x:Key="SurfaceBaseColor">#0B121D</Color>
        <Color x:Key="PanelDeepColor">#0D1520</Color>
        <Color x:Key="SurfacePanelColor">#0E1825</Color>
        <Color x:Key="SurfaceBorderColor">#152030</Color>

        <!-- Palette brushes (derived from the colors above) -->
        <SolidColorBrush x:Key="PrimaryAccent" Color="{StaticResource PrimaryAccentColor}" />
        <SolidColorBrush x:Key="SoftAccent" Color="{StaticResource SoftAccentColor}" />
        <SolidColorBrush x:Key="DeepBase" Color="{StaticResource DeepBaseColor}" />
        <SolidColorBrush x:Key="TextActive" Color="{StaticResource TextActiveColor}" />
        <SolidColorBrush x:Key="SurfaceBase" Color="{StaticResource SurfaceBaseColor}" />
        <SolidColorBrush x:Key="PanelDeep" Color="{StaticResource PanelDeepColor}" />
        <SolidColorBrush x:Key="SurfacePanel" Color="{StaticResource SurfacePanelColor}" />
        <SolidColorBrush x:Key="SurfaceBorder" Color="{StaticResource SurfaceBorderColor}" />

        <!-- Override AvaloniaEdit SearchPanel to use Zaide palette -->
        <SolidColorBrush x:Key="SearchPanelBackgroundBrush" Color="{StaticResource SurfacePanelColor}" />
        <SolidColorBrush x:Key="SearchPanelBorderBrush" Color="{StaticResource SurfaceBorderColor}" />
    </Application.Resources>

    <Application.Styles>
        <fluent:FluentTheme />
        <StyleInclude Source="avares://Semi.Avalonia/SemiTheme.axaml" />
        <StyleInclude Source="avares://AvaloniaEdit/Themes/Fluent/AvaloniaEdit.xaml" />
    </Application.Styles>
</Application>
