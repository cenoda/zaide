<!-- Unsaved changes dialog per DESIGN.md §1 tier-2 (simple button layout reads better in XAML). -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Zaide.Views.UnsavedDialog"
        Title="Unsaved Changes"
        Width="400" Height="160"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False">

    <!-- Margin is Thickness; Spacing* tokens are Double. Apply uniform
         SpacingXl margin from code-behind via LayoutTokens (not StaticResource). -->
    <StackPanel x:Name="RootPanel" Spacing="{StaticResource SpacingLg}">
        <TextBlock x:Name="MessageText"
                   TextWrapping="Wrap" />

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="{StaticResource SpacingSm}">
            <Button x:Name="SaveButton" Content="Save" Width="90" />
            <Button x:Name="DontSaveButton" Content="Don't Save" Width="90" />
            <Button x:Name="CancelButton" Content="Cancel" Width="90" />
        </StackPanel>
    </StackPanel>
</Window>
